---
// src/components/sections/ModuleShowcase.astro
//
// کامپوننت قابل استفاده مجدد برای معرفی هر ماژول مافیکسو.
// برای هر ماژول جدید، فقط این کامپوننت رو با props متفاوت صدا بزن —
// نیازی به کپی کردن مارک‌آپ نیست.
//
// نمونه استفاده در پایین فایل (پس از export) با محتوای «ماژول مدیریت دستگاه‌ها».

interface SubFeature {
  title: string;
  description: string;
}

interface Props {
  moduleNumber: string; // مثال: "۰۱"
  title: string;
  titleIcon:string;
  description: string;
  subFeatures: SubFeature[]; // ترجیحاً ۴ آیتم برای تناسب با گرید ۲×۲
  previewImage?: string; // اسکرین‌شات یا mockup ماژول (اختیاری)
  demoHref?: string;
  reversed?: boolean; // برای چیدمان متناوب ماژول‌ها در صفحه (زیگزاگ / mirror)
  layout?: "image-first" | "title-first"; // ترتیب ستون عکس و ستون عنوان؛ گرید همیشه وسط می‌ماند
}

const {
  moduleNumber,
  title,
  titleIcon = '/icons/img_15.svg',
  description,
  subFeatures,
  previewImage,
  demoHref = "/demo",
  reversed = false,
  layout = "image-first",
} = Astro.props;

// گرید امکانات همیشه ستون وسط است. فقط ترتیب ستون عکس و ستون عنوان جا‌به‌جا می‌شود.
const previewOrderClass = layout === "title-first" ? "lg:order-3" : "lg:order-1";
const titleOrderClass = layout === "title-first" ? "lg:order-1" : "lg:order-3";
---

<section class="relative my-24 py-12" aria-labelledby={`module-${moduleNumber}-heading`}>
  <div class="max-w-content mx-auto px-4">

    <div
      class:list={[
        "relative rounded-[20px] sm:rounded-[30px]  shadow-1 border border-lavender grid grid-cols-12 gap-6 sm:gap-[30px] p-4 sm:p-[30px] items-center bg-[#ffffff31]",
        reversed && "lg:[direction:rtl]",
      ]}
    >
    <div class="absolute hidden lg:block rtl:-right-5 ltr:-left-5 w-5 h-[91%] bg-[#f5f4f4] shadow-2 ltr:rounded-r-[15px] ltr:sm:rounded-l-[30px]  rtl:rounded-r-[15px] rtl:sm:rounded-r-[30px]">
            </div>
            <div class="absolute hidden lg:block rtl:-right-10 ltr:-left-10  w-5 h-[80%] my-[80px] bg-[#efefef] shadow-2 ltr:rounded-r-[15px] ltr:sm:rounded-l-[30px]  rtl:rounded-r-[15px] rtl:sm:rounded-r-[30px]">
            </div>

      <!-- پیش‌نمایش ماژول (جایگزین اسلایدر نمونه‌کار) -->
      <div class:list={["col-span-12 lg:col-span-4 order-2", previewOrderClass]}>
        <div class="bg-white rounded-[20px] sm:rounded-[30px] p-3 sm:p-6">
          {previewImage ? (
            <img
              src={previewImage}
              alt={`پیش‌نمایش ${title}`}
              class="w-full h-[220px] sm:h-[300px] object-cover rounded-[15px] sm:rounded-[20px]"
              loading="lazy"
            />
          ) : (
            <div
              class="w-full h-[220px] sm:h-[300px] rounded-[15px] sm:rounded-[20px] bg-white border-2 border-dashed border-lavender flex items-center justify-center"
              role="img"
              aria-label={`پیش‌نمایش ${title} به‌زودی اضافه می‌شود`}
            >
              <span class="text-charcoal/40 text-sm">پیش‌نمایش ماژول</span>
            </div>
          )}
        </div>

        <div class="mt-5 flex items-center gap-3">
          <a
            href={demoHref}
            class="bg-secondary rounded-[16px] flex-grow py-3 px-6 flex items-center justify-center text-sm font-bold text-white hover:bg-secondary/90 transition-all duration-300"
          >
            مشاهده در دمو
          </a>
        </div>
      </div>

      <!-- گرید امکانات این ماژول (همیشه وسط) -->
      <div class="col-span-12 lg:col-span-5 order-3 lg:order-2">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
          {subFeatures.map((feature, i) => (
            <div class="bg-[url('/images/Rectangle103.png')] bg-cover p-3 pb-5 rounded-b-3xl ">
              <div
                class="size-12 flex items-center justify-center bg-primary text-white  font-black rounded-[10px] mb-3"
                aria-hidden="true"
              >
                {i + 1}
              </div>
              <h4 class="text-primary font-bold text-sm sm:text-base leading-6 mb-2">
                {feature.title}
              </h4>
              <p class="text-charcoal/60 text-xs sm:text-sm leading-6">
                {feature.description}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- عنوان و توضیح ماژول -->
      <div class:list={["col-span-12 lg:col-span-3 order-1 relative h-full flex flex-col items-start justify-center", titleOrderClass]}>
        <img alt="bg" src="/images/Rectangle3.png" class="rtl:[transform:rotateY(180deg)] absolute  drop-shadow-1 h-full w-full -z-10">
        <div class="px-3">
            <img src={titleIcon} alt="" class="size-12 z-20 absolute top-[10%] left-[10%]">
            <div class="inline-flex items-center gap-2 bg-white rounded-full px-6 py-1.5 mb-5 z-10 ">
                <span class="text-secondary font-bold ">ماژول</span>
                <span class="text-secondary font-black ">{moduleNumber}</span>
            </div>
            <h2 id={`module-${moduleNumber}-heading`} class="text-xl sm:text-3xl font-heading font-extrabold text-primary leading-tight z-10">
                {title}
            </h2>
            <p class="text-charcoal/60 text-sm leading-7 mt-3 z-10 text-justify">
                {description}
            </p>
        </div>
      </div>
    </div>
  </div>
</section>