---

<section class="relative my-24">
    <div class="max-w-content mx-auto px-4 relative">
        <img alt="img" src="/images/Pattern.png" class="absolute rtl:right-0 ltr:left-0 ltrReverse -top-64 hidden md:block opacity-5">
        <div>
            <div class="rounded-t-[20px] sm:rounded-t-[30px] bg-[#fcfcfc] shadow-2 z-1 h-5 mx-[59px] relative"></div>
            <div class="rounded-t-[20px] sm:rounded-t-[30px] bg-[#f4f4f4] shadow-2 h-5 mx-[30px] relative"></div>
            <div class="rounded-[20px] sm:rounded-[30px] bg-[#F2F2F2] shadow-2 pt-4 relative overflow-hidden">
                <svg class="-top-[5px] rtl:right-[45px] rtl:sm:right-[62px] ltr:left-[45px] ltr:sm:left-[62px] absolute z-10" width="44" height="24" viewBox="0 0 74 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M73.603 0H0C14.1842 0 27.3009 7.53381 34.4478 19.7859L36.8642 23.9282L39.2806 19.7859C46.4065 7.57007 59.4669 0.0443115 73.603 0Z" fill="#e6e6e6"></path>
                </svg>
                <div class="flex items-center justify-between gap-2 px-5 sm:px-[38px]">
                    <div class="flex items-center gap-9">
                        <div class="relative">
                            <div class="w-5 h-5 shadow-5 absolute top-1 rtl:right-1 ltr:left-1 bg-[#fdeeea]"></div>
                            <svg class="relative" width="30" height="31" viewBox="0 0 30 31" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M17.5 23C17.5 23 18.75 23 20 25.5C20 25.5 23.9713 19.25 27.5 18" stroke="#EE5D38" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                                <path d="M16.25 28H8.23745C6.3062 28 4.76995 27.06 3.3912 25.7463C0.566202 23.055 5.2037 20.905 6.97245 19.8525C10.945 17.4863 15.9412 17.3875 20 19.5538M20.625 8.625C20.625 10.1168 20.0323 11.5476 18.9774 12.6025C17.9225 13.6574 16.4918 14.25 15 14.25C13.5081 14.25 12.0774 13.6574 11.0225 12.6025C9.96758 11.5476 9.37495 10.1168 9.37495 8.625C9.37495 7.13316 9.96758 5.70242 11.0225 4.64752C12.0774 3.59263 13.5081 3 15 3C16.4918 3 17.9225 3.59263 18.9774 4.64752C20.0323 5.70242 20.625 7.13316 20.625 8.625Z" stroke="#EE5D38" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="text-xl  text-primary">مشتریان ما</p>
                            <p class="hidden min-[928px]:block opacity-50 text-primary rtl:font-iranYekanLight ltr:font-MontserratRegular text-sm">
                                تعمیرگاه‌های معتبر ایران به رافیکـس اعتماد کرده‌اند
                            </p>
                        </div>
                    </div>
                </div>

                <div class="relative px-5 sm:px-[38px] py-6 " data-client-slider>
                    <div class="client-slider-viewport " id="clientSliderViewport">
                        <div class="client-slider-track flex bg-white" id="clientSlider">
                            {clients.map((client) => (
                                <div class="client-slide">
                                    <div class="bg-white rounded-[20px] sm:rounded-[30px] shadow-4 overflow-hidden relative px-[14px] pb-6">
                                        <img alt="img" src="/images/Frame1.png" class="absolute top-0 rtl:left-0 ltr:right-0 ltrReverse opacity-50">
                                        <img
                                            alt={client.name}
                                            src={client.logo}
                                            class="mt-[58px] mx-auto size-20 rounded-full object-cover border-4 border-[#f0f4fa]"
                                        >
                                        <div class="w-full h-[1px] bg-[#00000011] mt-[60px]"></div>
                                        <p class="text-center text-secondary font-bold mt-6 text-sm">{client.name}</p>
                                        <p class="text-center opacity-50 text-sm mt-2">{client.service}</p>
                                        
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Navigation Buttons -->
                    <div class="flex justify-center gap-4 mt-6">
                        <button id="clientPrevBtn" type="button" aria-label="اسلاید قبلی" class="!relative !static w-10 h-10 rounded-full bg-primary flex items-center justify-center cursor-pointer hover:bg-primary/80 transition">
                            <svg class="ltrReverse" width="19" height="14" viewBox="0 0 19 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path opacity="0.5" d="M1.65063 6.25003C1.45172 6.25003 1.26096 6.32905 1.1203 6.4697C0.979653 6.61035 0.900635 6.80112 0.900635 7.00003C0.900635 7.19894 0.979652 7.38971 1.1203 7.53036C1.26096 7.67101 1.45172 7.75003 1.65063 7.75003L1.65063 6.25003ZM1.65063 7.75003L17.6506 7.75003L17.6506 6.25003L1.65063 6.25003L1.65063 7.75003Z" fill="white"></path>
                                <path d="M11.6506 13L17.6506 7.00003L11.6506 1.00003" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </button>

                        <button id="clientNextBtn" type="button" aria-label="اسلاید بعدی" class="!relative !static w-10 h-10 rounded-full bg-primary flex items-center justify-center cursor-pointer hover:bg-primary/80 transition">
                            <svg class="ltrReverse" width="25" height="24" viewBox="0 0 25 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path opacity="0.5" d="M20.6489 12.75C20.8478 12.75 21.0386 12.671 21.1793 12.5303C21.3199 12.3897 21.3989 12.1989 21.3989 12C21.3989 11.8011 21.3199 11.6103 21.1793 11.4697C21.0386 11.329 20.8478 11.25 20.6489 11.25L20.6489 12.75ZM20.6489 11.25L4.64893 11.25L4.64893 12.75L20.6489 12.75L20.6489 11.25Z" fill="white"></path>
                                <path d="M10.6489 6L4.64892 12L10.6489 18" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </button>
                    </div>

                    <!-- Pagination -->
                    <div id="clientPagination" class="flex justify-center gap-2 mt-4"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<style is:global>
    .client-slider-viewport {
        overflow-x: auto;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior-x: contain;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    
    .client-slider-viewport::-webkit-scrollbar {
        display: none;
    }
    
    .client-slider-viewport.is-dragging {
        scroll-snap-type: none;
        cursor: grabbing;
    }
    
    .client-slide {
        flex: 0 0 100%;
        scroll-snap-align: start;
        padding: 0 15px;
        /* box-sizing: border-box; */
        background-color: rgb(255, 255, 255) !important;
    }

    @media (min-width: 640px) {
        .client-slide { flex-basis: 50%; }
    }

    @media (min-width: 768px) {
        .client-slide { flex-basis: 33.3333%; }
    }

    @media (min-width: 1024px) {
        .client-slide { flex-basis: 20%; }
    }

    #clientPagination .pagination-dot {
        width: 8px;
        height: 8px;
        background: #d1d1d1;
        opacity: 1;
        border-radius: 50%;
        border: none;
        padding: 0;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    #clientPagination .pagination-dot.active {
        width: 24px;
        background: #ee5d37;
        border-radius: 4px;
    }
</style>

<script>
    class ClientSlider {
        constructor(root) {
            this.root = root;
            this.viewport = root.querySelector('#clientSliderViewport');
            this.track = root.querySelector('#clientSlider');
            this.slides = Array.from(this.track.children);
            this.prevBtn = root.querySelector('#clientPrevBtn');
            this.nextBtn = root.querySelector('#clientNextBtn');
            this.pagination = root.querySelector('#clientPagination');

            this.autoplayDelay = 3500;
            this.autoplayTimer = null;
            this.currentPage = 0;
            this.isDragging = false;
            this.dots = [];

            this.init();
        }

        getItemsPerView() {
            const w = window.innerWidth;
            if (w >= 1024) return 4;
            if (w >= 768) return 3;
            if (w >= 640) return 2;
            return 1;
        }

        getTotalPages() {
            return Math.ceil(this.slides.length / this.getItemsPerView());
        }

        init() {
            this.buildPagination();
            this.observeSlides();
            this.bindControls();
            this.bindDrag();
            this.startAutoplay();

            let resizeTimer;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(() => {
                    this.buildPagination();
                    this.observeSlides();
                }, 200);
            });
        }

        buildPagination() {
            this.pagination.innerHTML = '';
            this.dots = [];
            const totalPages = this.getTotalPages();

            for (let i = 0; i < totalPages; i++) {
                const dot = document.createElement('button');
                dot.type = 'button';
                dot.className = 'pagination-dot' + (i === 0 ? ' active' : '');
                dot.setAttribute('aria-label', `اسلاید ${i + 1}`);
                dot.addEventListener('click', () => this.goToPage(i, true));
                this.pagination.appendChild(dot);
                this.dots.push(dot);
            }
        }

        observeSlides() {
            if (this.observer) this.observer.disconnect();
            const itemsPerView = this.getItemsPerView();

            this.observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
                        const index = this.slides.indexOf(entry.target);
                        const pageIndex = Math.floor(index / itemsPerView);
                        this.setActivePage(pageIndex);
                    }
                });
            }, { root: this.viewport, threshold: [0.6] });

            this.slides.forEach((slide) => this.observer.observe(slide));
        }

        setActivePage(pageIndex) {
            if (this.currentPage === pageIndex) return;
            this.currentPage = pageIndex;
            this.dots.forEach((dot, i) => dot.classList.toggle('active', i === pageIndex));
        }

        goToPage(pageIndex, userTriggered = false) {
            const itemsPerView = this.getItemsPerView();
            const totalPages = this.getTotalPages();
            const target = ((pageIndex % totalPages) + totalPages) % totalPages;
            const slideIndex = Math.min(target * itemsPerView, this.slides.length - 1);
            const slide = this.slides[slideIndex];

            slide?.scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
            this.setActivePage(target);

            if (userTriggered) this.resetAutoplay();
        }

        next() { this.goToPage(this.currentPage + 1); }
        prev() { this.goToPage(this.currentPage - 1); }

        bindControls() {
            this.nextBtn.addEventListener('click', () => { this.next(); this.resetAutoplay(); });
            this.prevBtn.addEventListener('click', () => { this.prev(); this.resetAutoplay(); });

            this.viewport.addEventListener('mouseenter', () => this.stopAutoplay());
            this.viewport.addEventListener('mouseleave', () => this.startAutoplay());
        }

        bindDrag() {
            let startX = 0;
            let scrollStart = 0;

            this.viewport.addEventListener('pointerdown', (e) => {
                if (e.pointerType !== 'mouse') return; // تاچ به‌صورت native کار می‌کنه
                this.isDragging = true;
                startX = e.clientX;
                scrollStart = this.viewport.scrollLeft;
                this.viewport.classList.add('is-dragging');
                this.stopAutoplay();
            });

            window.addEventListener('pointermove', (e) => {
                if (!this.isDragging) return;
                const delta = e.clientX - startX;
                this.viewport.scrollLeft = scrollStart - delta;
            });

            window.addEventListener('pointerup', () => {
                if (!this.isDragging) return;
                this.isDragging = false;
                this.viewport.classList.remove('is-dragging');
                this.startAutoplay();
            });
        }

        startAutoplay() {
            this.stopAutoplay();
            this.autoplayTimer = setInterval(() => this.next(), this.autoplayDelay);
        }

        stopAutoplay() {
            if (this.autoplayTimer) {
                clearInterval(this.autoplayTimer);
                this.autoplayTimer = null;
            }
        }

        resetAutoplay() {
            this.stopAutoplay();
            this.startAutoplay();
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const root = document.querySelector('[data-client-slider]');
        if (root) new ClientSlider(root);
    });
</script>