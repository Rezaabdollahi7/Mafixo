---
// src/components/sections/PricingHero.astro
---

<section class="relative  text-center mt-12" aria-labelledby="pricing-hero-heading">
  <div class="max-w-content mx-auto py-16 px-4 bg-white rounded-3xl">
    <div class="inline-flex items-center gap-3 bg-[#fdeeea] rounded-full px-6 py-2 mb-4" role="presentation">
      <span class="text-secondary font-bold text-sm">تعرفه‌های مافیکسو</span>
    </div>

    <h1 id="pricing-hero-heading" class="text-3xl md:text-4xl lg:text-5xl font-heading font-extrabold text-primary leading-tight">
      قیمتی مناسب برای <span class="text-secondary">هر اندازه تعمیرگاه</span>
    </h1>

    <p class="text-charcoal/60 text-base md:text-lg mt-4 max-w-2xl mx-auto">
      بدون نیاز به پرداخت  نسخه دمو مافیکسو را رایگان امتحان کنید و ببینید مدیریت تعمیرگاه‌تان چقدر منظم تر می‌شود.
    </p>

    <div class="mt-8">
      <a
        href="/demo"
        class="inline-flex items-center gap-2 bg-secondary text-white font-bold py-3 px-8 rounded-[12px] hover:bg-secondary/90 shadow-5 hover:shadow-8 transition-all duration-300"
      >
        مشاهده دمو رایگان
      </a>
    </div>
  </div>
</section>