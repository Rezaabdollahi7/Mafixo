---
// src/components/sections/Contact.astro
---

<section class="relative mt-42  z-10" id="contact" aria-labelledby="contact-heading">
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-4">
    <div class="rounded-[30px] bg-white shadow-1 relative p-3 sm:p-[30px] pt-4 shadow-2 grid grid-cols-12 items-center gap-3 sm:gap-6">
      
      <!-- ========== سمت راست - اطلاعات تماس ========== -->
      <div class="lg:col-span-8 col-span-12 order-last lg:order-first -mb-16 sm:-mb-[90px] lg:mb-0">
        
        <!-- هدر بخش -->
        <div class="lg:flex hidden items-center sm:gap-9 gap-8">
          <div class="relative">
            <div class="w-5 h-5 shadow-5 absolute top-1 right-1 bg-[#fdeeea] rounded-full"></div>
            <div class="w-5 h-5 shadow-5 bg-[#fdeeea] rounded-full"></div>
          </div>
          <div>
            <h2 class="sm:text-xl text-lg font-['Rokh'] font-extrabold text-[#110e2d]">تماس با ما</h2>
            <p class="opacity-50 text-[#110e2d] text-xs hidden sm:block font-['IRANYekanXFaNum']">
              تیم حرفه‌ای و پیشرفته ما آماده ارائه خدمات حرفه‌ای و درجه‌یک برای کسب‌وکار شما در هر زمینه‌ای برای پیشرفت و رشد میباشد
            </p>
          </div>
        </div>

        <!-- کارت‌های اطلاعات + نقشه -->
        <div class="flex flex-col lg:flex-row items-center lg:mt-4">
          
          <div class="bg-white w-full lg:w-auto relative rounded-[30px] shadow-1 p-4 sm:p-[30px] grid grid-cols-12 gap-4 lg:gap-6 z-20">
            
            <!-- دکوراسیون پس‌زمینه -->
            <div class="absolute z-0 hidden lg:block top-[76px] -right-14">
              <div class="w-20 h-20 bg-[#fdeeea] rounded-full blur-2xl opacity-40"></div>
            </div>

            <!-- ====== ایمیل ====== -->
            <div class="md:col-span-6 col-span-12">
              <div class="rounded-[18px] bg-[#fdeeea] h-full flex items-center gap-4 px-5 py-6 relative hover:shadow-lg transition-shadow duration-300">
                <div class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="text-[#110e2d] pr-4 border-r-2 border-[#00000012] border-dashed relative">
                  <p class="mt-2 font-['Rokh'] font-extrabold text-xs sm:text-lg">آدرس ایمیل</p>
                  <p class="mt-2 opacity-60 text-[10px] sm:text-sm sm:leading-7 leading-6 font-['IRANYekanXFaNum']">
                    پشتیبانی مشکلات فنی از طریق ایمیل
                    <br />
                    <span class="font-bold text-secondary">info@mafixo.ir</span>
                  </p>
                </div>
              </div>
            </div>

            <!-- ====== شماره تماس ====== -->
            <div class="md:col-span-6 col-span-12">
              <div class="rounded-[18px] bg-[#fdeeea] h-full flex items-center gap-4 px-5 py-6 relative hover:shadow-lg transition-shadow duration-300">
                <div class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div class="text-[#110e2d] pr-4 border-r-2 border-[#00000012] border-dashed relative">
                  <p class="mt-2 font-['Rokh'] font-extrabold text-xs sm:text-lg">شماره تماس</p>
                  <p class="mt-2 opacity-60 text-[10px] sm:text-sm sm:leading-7 leading-6 font-['IRANYekanXFaNum']">
                    پشتیبانی ۲۴ ساعته تیم مافیکسو
                    <br />

                    <a href="tel:09219811980" dir="ltr" class="font-bold text-secondary hover:underline">۰۹۲۱-۹۸۱-۱۹۸۰</a>
                    
                  </p>
                </div>
              </div>
            </div>

            <!-- ====== آدرس دفتر ====== -->
            <div class="col-span-12">
              <div class="rounded-[18px] bg-[#ecf1f7] flex items-center gap-4 px-5 py-6 relative hover:shadow-lg transition-shadow duration-300">
                <div class="w-12 h-12 rounded-full bg-gray-200/50 flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div class="text-[#110e2d] pr-4 border-r-2 border-[#00000012] border-dashed relative">
                  <p class="mt-2 font-['Rokh'] font-extrabold text-xs sm:text-lg">آدرس دفتر</p>
                  <p class="mt-2 opacity-60 text-[10px] sm:text-sm sm:leading-7 leading-6 font-['IRANYekanXFaNum']">
                    قزوین - شهر صنعتی البرز - بلوار سهروردی - ما بین حکمت اول و سوم - ساختمان چمران
                  </p>
                </div>
              </div>
            </div>

            <!-- ====== نقشه ====== -->
            <div class="col-span-12">
            <iframe
              class="rounded-[18px] overflow-hidden w-full h-56 sm:h-[200px] shadow-inner"
              src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d1616.0680753757124!2d50.08057843980947!3d36.198889235649816!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3f8cadbf407d90c7%3A0xd4297f225533f131!2zNTNYSCtYSjPYjCDYtNmH2LEg2LXZhti52KrbjCDYp9mE2KjYsdiy2Iwg2KfbjNix2KfZhg!5e0!3m2!1sfa!2sus!4v1783458192292!5m2!1sfa!2sus"
              width="600"
              height="450"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="نقشه دفتر مافیکسو"
            ></iframe>
            </div>
          </div>

          <!-- ستون‌های تزیینی -->
          <div class="rtl:lg:rounded-l-[30px] ltr:lg:rounded-r-[30px] rounded-b-[20px] lg:rounded-b-none shadow-2 w-[81%] sm:w-[89%] lg:w-6 h-4 lg:h-[500px] bg-white lg:bg-[#fdfdfd] relative z-10"></div>
          <div class="rtl:lg:rounded-l-[30px] ltr:lg:rounded-r-[30px] rounded-b-[20px] lg:rounded-b-none shadow-2 w-[72%] sm:w-[82%] lg:w-6 h-4 lg:h-[465px] bg-[#ebeaea] lg:bg-[#f1f0f0aa] relative z-0"></div>
        </div>
      </div>

      <!-- ========== سمت چپ - فرم مشاوره ========== -->
      <div class="lg:col-span-4 col-span-12">
        
        <div class="flex items-center gap-8">
          <div class="relative lg:hidden">
            <div class="w-5 h-5 shadow-5 absolute top-1 right-1 bg-[#fdeeea] rounded-full"></div>
            <div class="w-5 h-5 shadow-5 bg-[#fdeeea] rounded-full"></div>
          </div>
          <h3 class="rtl:lg:mr-[68px] ltr:lg:ml-[68px] text-xl font-['Rokh'] font-extrabold text-[#110e2d] flex items-center gap-2">
            <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            فرم رزرو وقت مشاوره
          </h3>
        </div>

        <form
          id="contact-form"
          class="w-full mt-[18px] bg-[#ecf1f7] rounded-[30px] p-4 sm:p-[30px] relative shadow-inner"
          action="/api/contact"
          method="POST"
        >
          <div class="space-y-4">
            
            <!-- نام و نام خانوادگی -->
            <div class="rounded-[12px] flex items-center bg-white text-xs font-normal h-11 shadow-sm hover:shadow-md transition-shadow">
              <input
                type="text"
                name="fullName"
                class="flex-grow py-4 px-4 bg-transparent outline-none w-full text-sm font-['IRANYekanXFaNum']"
                placeholder="نام و نام خانوادگی"
                required
              />
            </div>

            <!-- شماره تماس -->
            <div class="rounded-[12px] flex items-center bg-white text-xs font-normal h-11 shadow-sm hover:shadow-md transition-shadow">
              <input
                type="tel"
                name="phone"
                class="flex-grow py-4 px-4 bg-transparent outline-none w-full text-sm font-['IRANYekanXFaNum']"
                placeholder="شماره تماس"
                required
              />
            </div>

            <!-- ایمیل -->
            <div class="rounded-[12px] flex items-center bg-white text-xs font-normal h-11 shadow-sm hover:shadow-md transition-shadow">
              <input
                type="email"
                name="email"
                class="flex-grow py-4 px-4 bg-transparent outline-none w-full text-sm font-['IRANYekanXFaNum']"
                placeholder="آدرس ایمیل (اختیاری)"
              />
            </div>

            <!-- توضیحات -->
            <div class="bg-white overflow-hidden rounded-[12px] h-[100px] shadow-sm hover:shadow-md transition-shadow">
              <textarea
                name="message"
                class="bg-transparent outline-none w-full h-full p-4 text-sm resize-none font-['IRANYekanXFaNum']"
                placeholder="توضیحات"
              ></textarea>
            </div>


            <!-- دکمه ارسال -->
            <button
              type="submit"
              class="bg-secondary btnHover flex items-center justify-center gap-2 h-12 text-sm w-full cursor-pointer rounded-[12px] text-white font-bold shadow-8 hover:shadow-lg transition-all duration-300 font-['Rokh']"
            >
              ارسال پیام
              <svg class="w-5 h-5 -rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </button>

            <!-- شبکه‌های اجتماعی -->
            <div class="flex items-center justify-center gap-3 pt-2">
              <a
                href="#"
                class="w-10 h-10 rounded-[12px] bg-[#110e2d10] hover:bg-secondary hover:text-white flex items-center justify-center transition-all duration-300 text-[#110e2d]"
                aria-label="اینستاگرام"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                </svg>
              </a>
              <a
                href="#"
                class="w-10 h-10 rounded-[12px] bg-[#110e2d10] hover:bg-secondary hover:text-white flex items-center justify-center transition-all duration-300 text-[#110e2d]"
                aria-label="تلگرام"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0h-.056zm7.353 7.8l-1.807 8.519c-.138.597-.479.744-.972.462l-2.694-1.986-1.297 1.25c-.144.144-.264.264-.542.264l.19-2.734 4.982-4.5c.216-.194-.048-.3-.334-.108l-6.161 3.887-2.653-.83c-.577-.18-.577-.577.115-.853l10.315-3.968c.482-.174.902.108.722.857z" />
                </svg>
              </a>
              <a
                href="#"
                class="w-10 h-10 rounded-[12px] bg-[#110e2d10] hover:bg-secondary hover:text-white flex items-center justify-center transition-all duration-300 text-[#110e2d]"
                aria-label="واتساپ"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12.032 21.965a9.93 9.93 0 01-5.06-1.386l-3.63 1.184 1.213-3.525A9.835 9.835 0 012.05 12.04c0-5.5 4.483-9.967 9.992-9.967 5.509 0 9.992 4.467 9.992 9.966 0 5.499-4.483 9.966-9.992 9.966h-.01zM12.032 3.94C7.563 3.94 3.93 7.564 3.93 12.04a8.05 8.05 0 001.197 4.23l.235.368-.752 2.183 2.261-.737.356.213a8.054 8.054 0 004.277 1.219c4.47 0 8.105-3.624 8.105-8.1.001-4.476-3.635-8.1-8.105-8.1h.003z" />
                  <path d="M16.138 13.677c-.238-.119-1.41-.696-1.629-.776-.218-.08-.376-.119-.535.119-.159.238-.616.776-.755.935-.139.159-.278.179-.516.06-.238-.119-1.006-.371-1.916-1.183-.708-.634-1.186-1.417-1.325-1.656-.139-.238-.015-.367.104-.486.107-.108.238-.278.357-.417.119-.139.159-.238.238-.397.079-.159.04-.298-.02-.417-.06-.119-.535-1.291-.734-1.768-.193-.463-.389-.4-.535-.406-.139-.006-.298-.006-.457-.006s-.417.06-.636.298c-.219.238-.835.818-.835 1.995 0 1.177.853 2.314.972 2.474.119.159 1.678 2.561 4.065 3.473.568.217 1.012.347 1.358.443.571.185 1.09.158 1.501.095.458-.07 1.41-.576 1.608-1.132.198-.556.198-1.033.139-1.132-.059-.099-.218-.159-.456-.278z" />
                </svg>
              </a>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>