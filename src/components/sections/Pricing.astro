---

<section class="relative mt-42 " aria-labelledby="pricing-heading">
  <div class="max-w-content mx-auto px-4">
    <!-- Header -->
    <header class="text-center mb-12">
      <div class="inline-flex items-center gap-3 bg-[#fdeeea] rounded-full px-6 py-2 mb-4" role="presentation">
        <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-secondary font-bold text-sm">تعرفه‌ها</span>
      </div>
      
      <h2 id="pricing-heading" class="text-2xl md:text-3xl lg:text-4xl font-heading font-extrabold text-primary">
        قیمت‌های منعطف <span class="text-secondary">مافیکسو</span>
      </h2>
      
      <p class="text-charcoal/60 text-base md:text-lg mt-3 max-w-2xl mx-auto">
        با انتخاب پلن مناسب، مدیریت تعمیرات خود را متحول کنید
      </p>
    </header>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {pricingPlans.map((plan) => (
        <article 
          class:list={[
            "bg-white rounded-[20px] shadow-1 p-6 md:p-7 text-center hover:shadow-4 transition-all duration-300 relative overflow-hidden",
            plan.isPopular ? "border-2 border-secondary shadow-4 hover:shadow-8" : "border border-lavender"
          ]}
          aria-labelledby={`plan-${plan.id}`}
        >
          {plan.isPopular && (
            <div class="absolute -top-1 -right-1" aria-label="پیشنهاد ویژه">
              <div class="bg-secondary text-white text-[10px] font-bold px-4 py-1 rounded-bl-[15px] rounded-tr-[19px]">
                پیشنهاد ویژه
              </div>
            </div>
          )}
          
          <!-- Plan Header -->
          <div class="flex justify-center mb-2">
            <span 
              class:list={[
                "text-xs font-bold px-4 py-1 rounded-full",
                plan.isPopular ? "text-white bg-secondary" : "text-primary/40 bg-[#f0f4fa]"
              ]}
            >
              {plan.label}
            </span>
          </div>
          
          <h3 id={`plan-${plan.id}`} class="text-xl font-bold text-primary mb-1">
            {plan.title}
          </h3>
          
          <!-- Pricing -->
          <div class="my-4">
            <span class="text-5xl font-black text-primary">{plan.price}</span>
            <span class="text-md text-charcoal/60"> هزار تومان</span>
          </div>
          
          {plan.perDay ? (
            <p class="text-xs text-charcoal/40">{plan.perDay}</p>
          ) : plan.originalPrice && plan.discount && (
            <div class="flex items-center justify-center gap-2">
              <span class="text-xs text-charcoal/40 line-through">{plan.originalPrice}</span>
              <span class="text-sm text-secondary font-bold bg-[#fdeeea] px-4 py-1 rounded-full">
                {plan.discount}
              </span>
            </div>
          )}
          
          <!-- Features List -->
          <ul class="text-right mt-10 space-y-3 text-sm" role="list">
            {plan.features.map((feature) => (
              <li class="flex items-center gap-3">
                <svg 
                  class="w-5 h-5 text-secondary flex-shrink-0" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-charcoal/80">{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA Button -->
          <div class="mt-6">
            <a 
              href="/demo" 
              class:list={[
                "block w-full font-bold py-3 px-4 rounded-[12px] transition-all duration-300",
                plan.isPopular 
                  ? "bg-secondary text-white hover:bg-secondary/90 shadow-5 hover:shadow-8"
                  : "border-2 border-primary text-primary hover:bg-primary hover:text-white"
              ]}
              aria-label={`شروع رایگان با پلن ${plan.title}`}
            >
              شروع رایگان
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <aside class="text-center mt-12">
      <div class="bg-[#f0f4fa] rounded-[20px] p-6 md:p-8 max-w-3xl mx-auto">
        <p class="text-primary font-bold text-lg mb-5">
          <span class="text-secondary">نسخه دمو</span> رایگان در دسترس است!
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a 
            href="/demo" 
            class="inline-flex items-center gap-2 bg-primary text-white font-bold py-3 px-8 rounded-[12px] hover:bg-primary/90 transition-all duration-300"
            aria-label="مشاهده نسخه دمو"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            مشاهده دمو
          </a>
          
          <a 
            href="/pricing" 
            class="inline-flex items-center gap-2 text-primary font-bold hover:text-secondary transition-all duration-300"
            aria-label="مشاهده همه تعرفه‌ها"
          >
            مشاهده همه تعرفه‌ها
            <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </aside>
  </div>
</section>