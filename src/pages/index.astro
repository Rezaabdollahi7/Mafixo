---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro'
import "../styles/global.css";
import Header from '../components/ui/Header.astro'
import FeaturesSlides from '../components/sections/FeaturesSlides.astro'
import Footer from '../components/sections/Footer.astro'
import Stats from '../components/sections/Stats.astro'
import About from '../components/sections/About.astro'
import Comparison from '../components/sections/Comparison.astro'
import FAQ from '../components/sections/FAQ.astro'
import Hero from '../components/sections/Hero.astro'
import Pricing from '../components/sections/Pricing.astro'
import Contact from '../components/sections/Contact.astro'
import Screenshots from '../components/sections/Screenshots.astro';
import { generalFaqs } from '../data/generalFaqs';

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "مافیکسو",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://mafixo.ir",
  description: "مافیکسو نرم‌افزاری برای مدیریت پذیرش، پیگیری تعمیرات و فروش قطعات در تعمیرگاه‌های موبایل و لوازم خانگی است.",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: generalFaqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};  
---

<Layout title='مافیکسو | نرم‌افزار مدیریت تعمیرگاه و فروشگاه لوازم یدکی' description='مافیکسو نرم‌افزاری برای مدیریت پذیرش، پیگیری تعمیرات و فروش قطعات در تعمیرگاه‌های موبایل و لوازم خانگی است. از پراکندگی به نظم، با مافیکسو.'
  schema={[softwareSchema, faqSchema]}>
     <Header />
     <Hero/>
    <FeaturesSlides/>
    <Comparison/>
    <Screenshots/>
     <Pricing/>
    <Stats/>
    <About/>
    <Contact/>
    <FAQ/>
    <Footer/>
</Layout>